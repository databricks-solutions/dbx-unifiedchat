graph TB
    %% Main Entry Point
    User[User Query] --> SuperAgent[Super Agent<br/>ResponsesAgent Wrapper<br/>with Memory Support]
    
    %% Memory Integration
    Lakebase[(Lakebase Database<br/>Short-term & Long-term Memory)] -.-> SuperAgent
    SuperAgent -.checkpoints.-> Lakebase
    SuperAgent -.user memories.-> Lakebase
    
    %% Intent Detection & Clarification
    SuperAgent --> IntentNode[Intent Detection Node<br/>Analyze Intent Type]
    IntentNode --> IntentType{Intent<br/>Type?}
    
    IntentType -->|Meta Question| MetaAnswer[Answer Meta Question<br/>System Capabilities/Help]
    MetaAnswer --> SuperAgent
    
    IntentType -->|Unclear| ClarifyNode[Clarification Node<br/>Request Clarification]
    ClarifyNode --> User
    
    IntentType -->|Clear Query| PlanningAgent[Planning Agent<br/>Query Analysis & Breakdown]
    
    %% Planning Agent Process
    PlanningAgent --> VSSearch[Vector Search Tool<br/>Search Relevant Spaces]
    VSIndex[(Vector Search Index<br/>Enriched Genie Space Metadata<br/>chunk_type: space_summary)] --> VSSearch
    
    VSSearch --> CreatePlan[Create Execution Plan<br/>Analyze Sub-questions]
    CreatePlan --> DecisionRoute{Execution<br/>Route?}
    
    %% Path 1: Single Genie Agent
    DecisionRoute -->|Single Space| SingleGenieCall[Call Single Genie Agent<br/>Databricks ResponsesAgent]
    SingleGenieCall --> GenieAgent1[Genie Agent<br/>space_id specific]
    GenieAgent1 --> SQLExec1[SQL Execution Agent<br/>Execute Query]
    SQLExec1 --> DeltaTables1[(Delta Tables)]
    SQLExec1 --> SummarizeAgent1[Result Summarize Agent<br/>Format Results]
    SummarizeAgent1 --> SuperAgent
    
    %% Path 2: Multiple Spaces + Join - Table Route (Fast)
    DecisionRoute -->|Multi + Join<br/>Table Route| SQLTableAgent[SQL Synthesis Table Agent<br/>Use UC Function Tools]
    SQLTableAgent --> UCFunctions[UC Function Toolkit<br/>get_space_summary<br/>get_table_overview<br/>get_column_detail<br/>get_space_details]
    UCFunctions --> EnrichedTable[(Enriched Genie Docs<br/>Delta Table)]
    UCFunctions --> SQLTableAgent
    SQLTableAgent --> SQLExec2[SQL Execution Agent<br/>Execute Joined Query]
    SQLExec2 --> DeltaTables2[(Delta Tables)]
    SQLExec2 --> SummarizeAgent2[Result Summarize Agent<br/>Format Results]
    SummarizeAgent2 --> SuperAgent
    
    %% Path 3: Multiple Spaces + Join - Genie Route (Accurate)
    DecisionRoute -->|Multi + Join<br/>Genie Route| ParallelGenie[Parallel Async Calls<br/>to Multiple Genie Agents]
    ParallelGenie --> GenieAgent2A[Genie Agent A<br/>Sub-question 1]
    ParallelGenie --> GenieAgent2B[Genie Agent B<br/>Sub-question 2]
    GenieAgent2A --> SQLGenieAgent[SQL Synthesis Genie Agent<br/>Combine SQL Results]
    GenieAgent2B --> SQLGenieAgent
    SQLGenieAgent --> SQLExec3[SQL Execution Agent<br/>Execute Combined Query]
    SQLExec3 --> DeltaTables3[(Delta Tables)]
    SQLExec3 --> SummarizeAgent3[Result Summarize Agent<br/>Format Results]
    SummarizeAgent3 --> SuperAgent
    
    %% Path 4: Multiple Spaces - No Join (Verbal Merge)
    DecisionRoute -->|Multi - No Join<br/>Verbal Merge| MultiGenie[Call Multiple Genie Agents<br/>in Parallel]
    MultiGenie --> GenieAgent3A[Genie Agent A<br/>Independent Question 1]
    MultiGenie --> GenieAgent3B[Genie Agent B<br/>Independent Question 2]
    GenieAgent3A --> VerbalMerge[Verbal Merge<br/>Integrate Answers]
    GenieAgent3B --> VerbalMerge
    VerbalMerge --> SummarizeAgent4[Result Summarize Agent<br/>Format Merged Results]
    SummarizeAgent4 --> SuperAgent
    
    %% Final Output
    SuperAgent --> FinalAnswer[Final Answer with<br/>thinking_result<br/>sql_result<br/>answer_result]
    FinalAnswer --> User
    
    %% ETL Pipeline Section (Build Order)
    subgraph ETLPipeline["ETL Pipeline - Build Order: 1 → 2 → 3 → 4"]
        direction TB
        
        subgraph Pipeline1["Notebook 1: Export Genie Spaces"]
            GSE1[Export Genie Spaces<br/>via API]
            GSE2[Save space.json to<br/>UC Volume]
            GSE1 --> GSE2
        end
        
        subgraph Pipeline2["Notebook 2: Enrich Table Metadata"]
            TMU1[Get Table Metadata<br/>DESCRIBE EXTENDED]
            TMU2[Sample Column Values<br/>Distinct Values]
            TMU3[Build Value Dictionary<br/>Frequency Counts]
            TMU4[Parse Genie space.json<br/>Create Baseline Docs]
            TMU5[Enrich Docs with<br/>Table Metadata]
            TMU6[Save to Delta Table<br/>enriched_genie_docs_chunks]
            TMU1 --> TMU2
            TMU2 --> TMU3
            TMU3 --> TMU5
            TMU4 --> TMU5
            TMU5 --> TMU6
        end
        
        subgraph Pipeline3["Notebook 3: Build Vector Search Index"]
            VS1[Create VS Endpoint<br/>if not exists]
            VS2[Enable CDC on<br/>enriched_genie_docs_chunks]
            VS3[Create Delta Sync Index<br/>embedding_source: searchable_content]
            VS4[Wait for Index ONLINE<br/>Test Search]
            VS1 --> VS2
            VS2 --> VS3
            VS3 --> VS4
        end
        
        Pipeline1 --> Pipeline2
        Pipeline2 --> Pipeline3
        Pipeline3 --> VSIndex
    end
    
    %% Supporting Data Tables
    EnrichedTable -.chunks.-> VSIndex
    
    %% MLflow Integration
    MLflow[MLflow<br/>Logging & Model Serving]
    SuperAgent -.logs & deploys.-> MLflow
    PlanningAgent -.logs.-> MLflow
    SQLTableAgent -.logs.-> MLflow
    SQLGenieAgent -.logs.-> MLflow
    SQLExec1 -.logs.-> MLflow
    SummarizeAgent1 -.logs.-> MLflow
    
    %% Styling
    classDef agentClass fill:#4A90E2,stroke:#2E5C8A,stroke-width:2px,color:#fff
    classDef dataClass fill:#50C878,stroke:#2E7D4E,stroke-width:2px,color:#fff
    classDef processClass fill:#F5A623,stroke:#C17D11,stroke-width:2px,color:#fff
    classDef decisionClass fill:#E94B3C,stroke:#A33428,stroke-width:2px,color:#fff
    classDef pipelineClass fill:#9B59B6,stroke:#6C3483,stroke-width:2px,color:#fff
    classDef memoryClass fill:#16A085,stroke:#117A65,stroke-width:2px,color:#fff
    
    class SuperAgent,PlanningAgent,GenieAgent1,GenieAgent2A,GenieAgent2B,GenieAgent3A,GenieAgent3B,SQLTableAgent,SQLGenieAgent,SummarizeAgent1,SummarizeAgent2,SummarizeAgent3,SummarizeAgent4 agentClass
    class VSIndex,DeltaTables1,DeltaTables2,DeltaTables3,EnrichedTable dataClass
    class IntentNode,VSSearch,CreatePlan,SingleGenieCall,ParallelGenie,MultiGenie,VerbalMerge,SQLExec1,SQLExec2,SQLExec3,UCFunctions,MetaAnswer,ClarifyNode processClass
    class IntentType,DecisionRoute decisionClass
    class GSE1,GSE2,TMU1,TMU2,TMU3,TMU4,TMU5,TMU6,VS1,VS2,VS3,VS4 pipelineClass
    class Lakebase memoryClass

