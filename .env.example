########
# usage: copy and rename to .env with your real env variable values. dont forget to add .env to .gitignore
#
# All names use short-name convention (no catalog.schema prefix).
# FQ names are derived at runtime via AgentConfig @property methods.
########

# Databricks Configuration
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapi************

# Unity Catalog Configuration (short names — FQ derived at runtime)
CATALOG_NAME=yyang
SCHEMA_NAME=multi_agent_genie

# UC Function short names (comma-separated)
UC_FUNCTION_NAMES=get_space_summary,get_table_overview,get_column_detail,get_space_instructions,get_space_details

# LLM Endpoints - Diversified by Agent Role
# Each agent can use a different model optimized for its specific task

# Default/Fallback endpoint (used if specific endpoint not set)
LLM_ENDPOINT=databricks-claude-sonnet-4-5

# Agent-Specific Endpoints (Balanced Configuration - Recommended)
LLM_ENDPOINT_CLARIFICATION=databricks-claude-haiku-4-5
LLM_ENDPOINT_PLANNING=databricks-claude-haiku-4-5
LLM_ENDPOINT_SQL_SYNTHESIS_TABLE=databricks-claude-haiku-4-5
LLM_ENDPOINT_SQL_SYNTHESIS_GENIE=databricks-claude-sonnet-4-5
LLM_ENDPOINT_EXECUTION=databricks-claude-haiku-4-5
LLM_ENDPOINT_SUMMARIZE=databricks-claude-haiku-4-5

# Alternative Configuration Examples:
# Budget-Conscious (Maximize Speed, Minimize Cost):
#   LLM_ENDPOINT_CLARIFICATION=databricks-claude-haiku-4-5
#   LLM_ENDPOINT_PLANNING=databricks-meta-llama-3-3-70b-instruct
#   LLM_ENDPOINT_SQL_SYNTHESIS_TABLE=databricks-claude-haiku-4-5
#   LLM_ENDPOINT_SQL_SYNTHESIS_GENIE=databricks-claude-haiku-4-5
#   LLM_ENDPOINT_EXECUTION=databricks-claude-haiku-4-5
#   LLM_ENDPOINT_SUMMARIZE=databricks-claude-haiku-4-5
#
# Quality-First (Maximize Accuracy):
#   LLM_ENDPOINT_CLARIFICATION=databricks-claude-sonnet-4-5
#   LLM_ENDPOINT_PLANNING=databricks-claude-sonnet-4-5
#   LLM_ENDPOINT_SQL_SYNTHESIS_TABLE=databricks-claude-sonnet-4-5
#   LLM_ENDPOINT_SQL_SYNTHESIS_GENIE=databricks-claude-sonnet-4-5
#   LLM_ENDPOINT_EXECUTION=databricks-claude-sonnet-4-5
#   LLM_ENDPOINT_SUMMARIZE=databricks-claude-sonnet-4-5

# Vector Search Configuration
VS_ENDPOINT_NAME=genie_multi_agent_vs
EMBEDDING_MODEL=databricks-gte-large-en
PIPELINE_TYPE=TRIGGERED

# Table / Volume names (short names — FQ derived at runtime)
ENRICHED_DOCS_TABLE=enriched_genie_docs
SOURCE_TABLE=enriched_genie_docs_chunks
VOLUME_NAME=volume

# Table Metadata Enrichment
SAMPLE_SIZE=100
MAX_UNIQUE_VALUES=50

# Genie space ids (comma-separated)
GENIE_SPACE_IDS=01f0956a54af123e9cd23907e8167df9,01f0956a387714969edde65458dcc22a,01f0956a4b0512e2a8aa325ffbac821b

# SQL Warehouse Configuration
# Required for SQLExecutionAgent to execute queries via SQL Warehouse
# Get warehouse ID from: SQL Warehouses UI → Click warehouse → Copy ID from URL or Details
SQL_WAREHOUSE_ID=148ccb90800933a1

# Model Serving (short name — FQ derived at runtime)
MODEL_NAME=super_agent_hybrid
ENDPOINT_NAME=multi-agent-genie-endpoint
WORKLOAD_SIZE=Small
SCALE_TO_ZERO=true

# Genie Room Migration (used by scripts/migrate_genie_rooms.py)
# Set these when migrating Genie spaces to a different workspace.
# If source == target, leave TARGET_* blank – DATABRICKS_HOST/TOKEN will be used.
TARGET_DATABRICKS_HOST=https://target-workspace.cloud.databricks.com
TARGET_DATABRICKS_TOKEN=dapi_target_token_here
# Target SQL Warehouse ID — leave blank to auto-detect an existing serverless warehouse
# or auto-create a new Small serverless warehouse on the target workspace.
TARGET_SQL_WAREHOUSE_ID=
# GENIE_IMPORT_PARENT_PATH=/Workspace/Users/you@example.com/Genie Spaces

# Lakebase Configuration (for State Management)
# Create instance in: SQL Warehouses -> Lakebase Postgres -> Create database instance
LAKEBASE_INSTANCE_NAME=agent-state-db
LAKEBASE_EMBEDDING_ENDPOINT=databricks-gte-large-en
LAKEBASE_EMBEDDING_DIMS=1024
